# Environment variables for the application. Copy this file to .env and fill in the values.
OPENAI_API_KEY=
OPENAI_BASE_URL=
CHAT_MODEL=

# Application data relative paths are resolved from algorithm-rag/ and remain under algorithm-rag/data/.
DATABASE_URL=sqlite:///./data/app.db
CHROMA_DIR=./data/chroma
UPLOAD_DIR=./data/uploads

JWT_SECRET_KEY=replace-with-a-long-random-string
JWT_EXPIRE_MINUTES=1440

RAG_TOP_K=8
RERANK_TOP_K=4
MAX_UPLOAD_MB=20
MAX_CHAT_MESSAGE_CHARS=4000

EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
# Embedding cache relative paths are resolved from the repository root.
EMBEDDING_CACHE_DIR=.venv/huggingface